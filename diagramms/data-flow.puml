@startuml
title abtop-py Data Flow

skinparam shadowing false
left to right direction

rectangle "Local Sources" as Sources {
  file "Claude session JSON" as ClaudeSession
  file "Claude transcript JSONL" as ClaudeTranscript
  file "Codex rollout JSONL" as CodexRollout
  file "Config and rate-limit cache" as ConfigCache
  node "Process table, ports,\nand host metrics" as Processes
  file "Git working trees" as GitTrees
}

rectangle "Collection" as Collection {
  component "ClaudeCollector" as ClaudeCollector
  component "CodexCollector" as CodexCollector
  component "Process helpers" as ProcessHelpers
  component "Rate-limit readers" as RateReaders
  component "Activity aggregation" as ActivityAggregation
}

rectangle "Normalization" as Normalization {
  class "AgentSession" as AgentSession
  class "ToolCall" as ToolCall
  class "ChatMessage\nwith timestamp" as ChatMessage
  class "RateLimitInfo" as RateLimitInfo
  class "ProjectActivity" as ProjectActivity
  class "HostMetrics" as HostMetrics
}

rectangle "Presentation" as Presentation {
  component "Curses dashboard" as Dashboard
  component "Text snapshot" as TextSnapshot
  component "JSON snapshot" as JsonSnapshot
}

ClaudeSession --> ClaudeCollector
ClaudeTranscript --> ClaudeCollector
CodexRollout --> CodexCollector
Processes --> ProcessHelpers
GitTrees --> ProcessHelpers
ConfigCache --> RateReaders

ClaudeCollector --> AgentSession
CodexCollector --> AgentSession
ProcessHelpers --> AgentSession
ProcessHelpers --> HostMetrics
RateReaders --> RateLimitInfo
AgentSession --> ToolCall
AgentSession --> ChatMessage
AgentSession --> ActivityAggregation
ActivityAggregation --> ProjectActivity

AgentSession --> Dashboard
RateLimitInfo --> Dashboard
ProjectActivity --> Dashboard
HostMetrics --> Dashboard
AgentSession --> TextSnapshot
AgentSession --> JsonSnapshot
RateLimitInfo --> JsonSnapshot

note bottom of Sources
All data is read from the local machine.
No provider API calls are required.
end note
@enduml
